# ─────────────────────────────────────────────────────────────────────────────
# MarketIQ Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# IMPORTANT: Restart `npm run dev` after any change to this file.
# ─────────────────────────────────────────────────────────────────────────────

# Backend URL (FastAPI — must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Google OAuth Client ID
# ⚠️  This MUST be the same value as GOOGLE_CLIENT_ID in the backend .env
# How to get it:
#   1. Go to https://console.cloud.google.com/
#   2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorised JavaScript origins: http://localhost:3000
#   5. Copy the Client ID below
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
